# =============================================================================
# Hand-drawn Animation Agent — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.
# =============================================================================

# -----------------------------------------------------------------------------
# Volcengine (火山引擎) credentials
# Create at: https://console.volcengine.com/iam/keymanage/
# -----------------------------------------------------------------------------
VOLC_ACCESSKEY=YOUR_VOLC_ACCESSKEY_HERE
VOLC_SECRETKEY=YOUR_VOLC_SECRETKEY_HERE

# -----------------------------------------------------------------------------
# DeepSeek API key  (used as the LLM for planning + prompt enhancement)
# Create at: https://platform.deepseek.com/api_keys
# -----------------------------------------------------------------------------
DEEPSEEK_API_KEY=YOUR_DEEPSEEK_API_KEY_HERE

# -----------------------------------------------------------------------------
# Telegram Bot
# 1. Message @BotFather on Telegram -> /newbot -> follow prompts
# 2. Copy the token here
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# -----------------------------------------------------------------------------
# Feishu (Lark) Bot
# 1. open.feishu.cn -> Create App -> Credentials & Basic Info
# 2. Permissions: im:message:send_as_bot, im:resource
# 3. Event Subscriptions -> im.message.receive_v1
#    Request URL: https://your-server.com/feishu/event
# 4. Copy Verification Token from Event Subscriptions page
# -----------------------------------------------------------------------------
FEISHU_APP_ID=YOUR_FEISHU_APP_ID_HERE
FEISHU_APP_SECRET=YOUR_FEISHU_APP_SECRET_HERE
FEISHU_VERIFICATION_TOKEN=YOUR_FEISHU_VERIFICATION_TOKEN_HERE
FEISHU_ENCRYPT_KEY=                          # leave blank if encryption disabled

# -----------------------------------------------------------------------------
# Replicate API  (figurine -> anime pipeline)
# 1. Register at https://replicate.com
# 2. Account -> API Tokens -> copy token
# -----------------------------------------------------------------------------
REPLICATE_API_TOKEN=r8_YOUR_TOKEN_HERE

# Public base URL — Feishu bot downloads files and serves them via /media/
# For local dev: run `ngrok http 8000` and paste the https URL here
PUBLIC_BASE_URL=https://your-server.com

# -----------------------------------------------------------------------------
# moomoo OpenAPI / OpenD
# 1. Install OpenD from the official moomoo OpenAPI docs
# 2. Start OpenD locally and sign in with your moomoo account
# 3. The demo fetch script will connect to this local gateway
# -----------------------------------------------------------------------------
MOOMOO_HOST=127.0.0.1
MOOMOO_PORT=11111
MOOMOO_MARKET_PREFIX=US

# -----------------------------------------------------------------------------
# MirrorQuant Social DNA
# 1. Finnhub key from https://finnhub.io/
# 2. NewsAPI key from https://newsapi.org/
# 3. FinBERT model is downloaded automatically from Hugging Face on first use
# -----------------------------------------------------------------------------
FINNHUB_API_KEY=YOUR_FINNHUB_API_KEY_HERE
NEWSAPI_API_KEY=YOUR_NEWSAPI_API_KEY_HERE

# -----------------------------------------------------------------------------
# MirrorQuant product app
# -----------------------------------------------------------------------------
MIRRORQUANT_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/mirrorquant
MIRRORQUANT_SESSION_SECRET=change-me
MIRRORQUANT_FRONTEND_URL=http://127.0.0.1:3000

MIRRORQUANT_DEV_EMAIL=cheng.kw0123@gmail.com
MIRRORQUANT_DEV_PASSWORD=mirrorquant123
MIRRORQUANT_PASSWORD_HASH_ITERATIONS=390000
MIRRORQUANT_VERIFICATION_TTL_HOURS=24

MIRRORQUANT_SMTP_HOST=smtp.gmail.com
MIRRORQUANT_SMTP_PORT=587
MIRRORQUANT_SMTP_USERNAME=cheng.kw0123@gmail.com
MIRRORQUANT_SMTP_PASSWORD=deed cccx vkdz kvby
MIRRORQUANT_SMTP_FROM_EMAIL=no-reply@mirrorquant.app
MIRRORQUANT_SMTP_USE_TLS=true
MIRRORQUANT_SMTP_USE_SSL=false
